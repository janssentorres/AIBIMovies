@model MvcMovie.Models.MovieGenreViewModel

@{
    ViewData["Title"] = "Movies";

    string NextSortDirection(string column)
    {
        return Model.SortBy == column && Model.SortDirection == "asc" ? "desc" : "asc";
    }

    string SortIndicator(string column)
    {
        if (Model.SortBy != column)
        {
            return string.Empty;
        }

        return Model.SortDirection == "asc" ? " ▲" : " ▼";
    }
}

<h1>Movies</h1>

<p> <a asp-action="Create">Create New</a> </p>

<form id="movieFilterForm" asp-controller="Movies" asp-action="Index" method="get" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="searchString" class="form-label">
                Title
            </label>
            <input type="text"
                   id="searchString"
                   name="searchString"
                   value="@Model.SearchString"
                   class="form-control"
                   placeholder="Search title" />
        </div>

        <div class="col-md-2">
            <label for="movieGenre" class="form-label"> Genre </label>
            <select id="movieGenre" name="movieGenre" class="form-select" asp-items="Model.Genres">
                <option value="">All</option>
            </select>
        </div>

        <div class="col-md-2">
            <label for="releaseDateFrom" class="form-label"> Release Date From </label>
            <input type="date"
                   id="releaseDateFrom"
                   name="releaseDateFrom"
                   value="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>

        <div class="col-md-2">
            <label for="releaseDateTo" class="form-label"> Release Date To </label>
            <input type="date"
                   id="releaseDateTo"
                   name="releaseDateTo"
                   value="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary"> Search </button>
            <a asp-action="Index" class="btn btn-secondary"> Clear </a>
        </div>
    </div>

    <input type="hidden"
           name="sortBy"
           value="@Model.SortBy" />

    <input type="hidden"
           name="sortDirection"
           value="@Model.SortDirection" />

    <input type="hidden"
           name="pageNumber"
           value="1" />
</form>

<div class="mb-2"> Showing page @Model.PageNumber of @Model.TotalPages — @Model.TotalRecords total records </div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortBy="Title"
                   asp-route-sortDirection="@NextSortDirection("Title")"
                   asp-route-searchString="@Model.SearchString"
                   asp-route-movieGenre="@Model.MovieGenre"
                   asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-pageNumber="1"
                   title="Sort by Title @NextSortDirection("Title")">
                    Title@(SortIndicator("Title"))
                </a>
            </th>

            <th>
                <a asp-action="Index"
                   asp-route-sortBy="ReleaseDate"
                   asp-route-sortDirection="@NextSortDirection("ReleaseDate")"
                   asp-route-searchString="@Model.SearchString"
                   asp-route-movieGenre="@Model.MovieGenre"
                   asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-pageNumber="1"
                   title="Sort by Release Date @NextSortDirection("ReleaseDate")">
                    Release Date@(SortIndicator("ReleaseDate"))
                </a>
            </th>

            <th>
                <a asp-action="Index"
                   asp-route-sortBy="Genre"
                   asp-route-sortDirection="@NextSortDirection("Genre")"
                   asp-route-searchString="@Model.SearchString"
                   asp-route-movieGenre="@Model.MovieGenre"
                   asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-pageNumber="1"
                   title="Sort by Genre @NextSortDirection("Genre")">
                    Genre@(SortIndicator("Genre"))
                </a>
            </th>

            <th> Price </th>
            <th> Rating </th>
            <th> Actions </th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Movies.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center"> No movies matched the selected filters. </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Movies)
            {
                <tr>
                    <td> @Html.DisplayFor(modelItem => item.Title) </td>
                    <td> @item.ReleaseDate.ToString("yyyy-MM-dd") </td>
                    <td> @Html.DisplayFor(modelItem => item.Genre) </td>
                    <td> @Html.DisplayFor(modelItem => item.Price) </td>
                    <td> @Html.DisplayFor(modelItem => item.Rating) </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id"> Edit </a>
                        |
                        <a asp-action="Details" asp-route-id="@item.Id"> Details </a>
                        |
                        <a asp-action="Delete" asp-route-id="@item.Id"> Delete </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>



<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div class="d-flex align-items-center gap-2">
        <label for="pageSize" class="form-label mb-0 text-nowrap"> Page Size </label>
        <select id="pageSize" name="pageSize" class="form-select" form="movieFilterForm" onchange="document.getElementById('movieFilterForm').submit()">
            <option value="10" selected="@(Model.PageSize == 10)"> 10 </option>
            <option value="50" selected="@(Model.PageSize == 50)"> 50 </option>
            <option value="100" selected="@(Model.PageSize == 100)"> 100 </option>
            <option value="200" selected="@(Model.PageSize == 200)"> 200 </option>
        </select>
    </div>
    <nav aria-label="Movie pagination">
        <ul class="pagination mb-0">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchString="@Model.SearchString"
                   asp-route-movieGenre="@Model.MovieGenre"
                   asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDirection="@Model.SortDirection">
                    Previous
                </a>
            </li>

            @{
                var startPage = Math.Max(1, Model.PageNumber - 2);
                var endPage = Math.Min(
                    Model.TotalPages,
                    Model.PageNumber + 2);
            }

            @for (var pageIndex = startPage; pageIndex <= endPage; pageIndex++)
            {
                <li class="page-item @(pageIndex == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@pageIndex"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-searchString="@Model.SearchString"
                       asp-route-movieGenre="@Model.MovieGenre"
                       asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-sortDirection="@Model.SortDirection">
                        @pageIndex
                    </a>
                </li>
            }

            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchString="@Model.SearchString"
                   asp-route-movieGenre="@Model.MovieGenre"
                   asp-route-releaseDateFrom="@Model.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-releaseDateTo="@Model.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDirection="@Model.SortDirection">
                    Next
                </a>
            </li>
        </ul>
    </nav>
</div>